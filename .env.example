# Copy to `.env` in this directory and fill in (`.env` is gitignored).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-12b-it

# Local GPU (Colab): not read by dotenv for USE_LOCAL_GEMMA_GPU — set that in the CONFIG notebook cell.
# LOCAL_GEMMA_MODEL_ID=google/gemma-3-12b-it
# HF_TOKEN=   # huggingface.co — required to download gated Gemma weights

# Optional pipeline toggles (see paddle_claim_pipeline.install_paddle_pipeline)
# USE_CLAIM_LEVEL_GEMMA=0
# USE_PAGE_IMAGE_CACHE=0
# SKIP_FULL_OCR_ON_TEXT_PDF=0
# USE_OCR_ADAPTIVE_THRESHOLD=1
